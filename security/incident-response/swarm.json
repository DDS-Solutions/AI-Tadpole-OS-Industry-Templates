{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Incident Response Swarm",
  "version": "1.0.0",
  "author": "SecOps Labs",
  "description": "Designed for security log auditing, incident triage, and automated mitigation recommendation.",
  "industry": "Cybersecurity",
  "tags": [
    "security",
    "secops",
    "incident-response"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.1
  },
  "roster": [
    {
      "id": "security-security-incident-responder",
      "path": "agents/security-security-incident-responder.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "engineering-engineering-incident-response-commander",
      "path": "agents/engineering-engineering-incident-response-commander.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "security-security-senior-secops",
      "path": "agents/security-security-senior-secops.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}