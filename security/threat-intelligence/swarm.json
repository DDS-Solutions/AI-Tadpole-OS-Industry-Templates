{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Threat Intel Feed Parser & Knowledge Base",
  "version": "1.0.0",
  "description": "Knowledge Work: Scraping CVE bulletins, threat intel feed indexing, and security alert briefings synthesis.",
  "industry": "cybersecurity",
  "tags": [
    "security",
    "threat-intel",
    "cve",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "security-security-architect",
      "path": "agents/security-security-architect.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-threat-detection-engineer",
      "path": "agents/security-security-threat-detection-engineer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "security-security-appsec-engineer",
      "path": "agents/security-security-appsec-engineer.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/threat_intel_sop.md"
  ]
}