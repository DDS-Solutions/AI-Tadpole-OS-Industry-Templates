{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Spare Parts Inventory & Fleet Purchasing QA",
  "version": "1.0.0",
  "description": "Edge Operations: Parts procurement, fleet shipping logs, inventory management, and maintenance QA.",
  "industry": "transportation-logistics",
  "tags": [
    "transportation",
    "procurement",
    "inventory",
    "parts",
    "maintenance-qa"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "engineering-engineering-it-service-manager",
      "path": "agents/engineering-engineering-it-service-manager.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "marketing-marketing-cross-border-ecommerce",
      "path": "agents/marketing-marketing-cross-border-ecommerce.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "marketing-marketing-private-domain-operator",
      "path": "agents/marketing-marketing-private-domain-operator.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/parts_sop.md"
  ]
}