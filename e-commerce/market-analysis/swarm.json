{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Competitor & Market Trend Analyzer",
  "version": "1.0.0",
  "description": "Knowledge Work: E-commerce catalog scraping, competitor pricing intelligence, and trend synthesis.",
  "industry": "e-commerce",
  "tags": [
    "e-commerce",
    "competitor-pricing",
    "trends",
    "market-analysis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "product-product-trend-researcher",
      "path": "agents/product-product-trend-researcher.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-specialized-pricing-analyst",
      "path": "agents/specialized-specialized-pricing-analyst.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "engineering-engineering-drupal-shopping-cart",
      "path": "agents/engineering-engineering-drupal-shopping-cart.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/market_analysis_sop.md"
  ]
}