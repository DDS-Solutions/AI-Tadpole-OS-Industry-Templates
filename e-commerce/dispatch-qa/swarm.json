{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Warehouse Dispatch & Shipping QA",
  "version": "1.0.0",
  "description": "Edge Operations: Shipping dispatch, receiving validation, inventory auditing, and packaging quality control.",
  "industry": "e-commerce",
  "tags": [
    "e-commerce",
    "shipping",
    "receiving",
    "inventory",
    "qa"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "marketing-marketing-china-ecommerce-operator",
      "path": "agents/marketing-marketing-china-ecommerce-operator.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "marketing-marketing-cross-border-ecommerce",
      "path": "agents/marketing-marketing-cross-border-ecommerce.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "marketing-marketing-livestream-commerce-coach",
      "path": "agents/marketing-marketing-livestream-commerce-coach.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/dispatch_sop.md"
  ]
}