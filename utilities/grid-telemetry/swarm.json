{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Grid Telemetry Swarm",
  "version": "1.0.0",
  "author": "GridSafe Networks",
  "description": "Designed for grid status logs auditing, alarm triage, and utility crew scheduling.",
  "industry": "Critical Infrastructure",
  "tags": [
    "utilities",
    "grid",
    "telemetry",
    "scada"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "alarm_monitor",
      "path": "agents/alarm_monitor.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "crew_scheduler",
      "path": "agents/crew_scheduler.json",
      "supervisor": "alarm_monitor",
      "priority": "high"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}
