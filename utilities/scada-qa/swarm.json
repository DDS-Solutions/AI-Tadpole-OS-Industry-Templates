{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "SCADA Device Shipping, Receiving & Hardware QA",
  "version": "1.0.0",
  "description": "Edge Operations: Grid sensor procurement, SCADA equipment shipping logs, receiving inspections, and hardware QA.",
  "industry": "critical-infrastructure",
  "tags": [
    "utilities",
    "scada",
    "shipping",
    "receiving",
    "hardware-qa",
    "procurement"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "engineering-engineering-devops-automator",
      "path": "agents/engineering-engineering-devops-automator.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-penetration-tester",
      "path": "agents/security-security-penetration-tester.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "support-support-infrastructure-maintainer",
      "path": "agents/support-support-infrastructure-maintainer.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/scada_receiving_sop.md"
  ]
}