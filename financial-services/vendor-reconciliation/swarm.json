{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Vendor Invoice & Purchasing QA",
  "version": "1.0.0",
  "description": "Edge Operations: Invoice processing, shipping validation, vendor ledger audits, and purchase reconciliation.",
  "industry": "financial-services",
  "tags": [
    "finance",
    "invoices",
    "reconciliation",
    "purchasing",
    "audit"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "finance-finance-bookkeeper-controller",
      "path": "agents/finance-finance-bookkeeper-controller.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-accounts-payable-agent",
      "path": "agents/specialized-accounts-payable-agent.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-chief-financial-officer",
      "path": "agents/specialized-chief-financial-officer.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/reconciliation_sop.md"
  ]
}