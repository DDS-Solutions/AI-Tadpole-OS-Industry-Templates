{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Tax Law & Policy Synthesizer",
  "version": "1.0.0",
  "description": "Knowledge Work: Financial research, tax law changes synthesis, policy auditing, and regulatory reporting.",
  "industry": "financial-services",
  "tags": [
    "finance",
    "tax",
    "policy",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "finance-finance-tax-strategist",
      "path": "agents/finance-finance-tax-strategist.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-chief-financial-officer",
      "path": "agents/specialized-chief-financial-officer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "finance-finance-bookkeeper-controller",
      "path": "agents/finance-finance-bookkeeper-controller.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/policy_sop.md"
  ]
}