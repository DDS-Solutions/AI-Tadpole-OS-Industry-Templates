{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Engineering Spec & Code Compliance Auditor",
  "version": "1.0.0",
  "description": "Knowledge Work: Reviewing structural specifications, municipal building codes indexing, and safety compliance audits.",
  "industry": "engineering-architecture",
  "tags": [
    "engineering",
    "compliance",
    "building-codes",
    "auditing"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "specialized-specialized-civil-engineer",
      "path": "agents/specialized-specialized-civil-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "engineering-engineering-cms-developer",
      "path": "agents/engineering-engineering-cms-developer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "security-security-architect",
      "path": "agents/security-security-architect.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/spec_review_sop.md"
  ]
}