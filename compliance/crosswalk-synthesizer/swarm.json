{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "SOC2/ISO Framework Crosswalk Synthesizer",
  "version": "1.0.0",
  "description": "Knowledge Work: Regulatory framework mapping, control guidelines synthesis, and security standard crosswalk audits.",
  "industry": "governance-compliance",
  "tags": [
    "compliance",
    "soc2",
    "iso27001",
    "crosswalk",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "engineering-engineering-it-service-manager",
      "path": "agents/engineering-engineering-it-service-manager.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "security-security-senior-secops",
      "path": "agents/security-security-senior-secops.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/crosswalk_sop.md"
  ]
}