{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Regulatory Compliance Swarm",
  "version": "1.0.0",
  "author": "TrustGuard SecOps",
  "description": "Continuous security posture assessment, SOC2/ISO readiness audits, and regulatory compliance mapping.",
  "industry": "Governance & Compliance",
  "tags": [
    "compliance",
    "audit",
    "security",
    "governance"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.1
  },
  "roster": [
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "finance-finance-bookkeeper-controller",
      "path": "agents/finance-finance-bookkeeper-controller.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}