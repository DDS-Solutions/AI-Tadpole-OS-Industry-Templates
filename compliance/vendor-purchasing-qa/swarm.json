{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Vendor Security Assessment & Procurement QA",
  "version": "1.0.0",
  "description": "Edge Operations: Vendor onboarding security checks, compliance audits, and procurement security QA.",
  "industry": "governance-compliance",
  "tags": [
    "compliance",
    "vendor-assessment",
    "procurement",
    "security-qa",
    "auditing"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-operations-manager",
      "path": "agents/specialized-operations-manager.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/vendor_qa_sop.md"
  ]
}