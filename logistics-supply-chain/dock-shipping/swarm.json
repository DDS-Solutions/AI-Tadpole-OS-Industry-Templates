{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Loading Dock Shipping & Receiving QA",
  "version": "1.0.0",
  "description": "Edge Operations: Freight loading, receiving, container seals inspections, inventory logging, and ISO 9000 audits.",
  "industry": "logistics-supply-chain",
  "tags": [
    "logistics",
    "shipping",
    "receiving",
    "iso9000",
    "warehouse"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "marketing-marketing-cross-border-ecommerce",
      "path": "agents/marketing-marketing-cross-border-ecommerce.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/dock_receiving_sop.md"
  ]
}