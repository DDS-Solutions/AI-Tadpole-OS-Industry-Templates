{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Route & Transit Strategy Analyzer",
  "version": "1.0.0",
  "description": "Knowledge Work: Freight data analysis, carrier performance indexing, transit delay prediction, and strategic synthesis.",
  "industry": "logistics-supply-chain",
  "tags": [
    "logistics",
    "route-planning",
    "transit-data",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "finance-finance-financial-analyst",
      "path": "agents/finance-finance-financial-analyst.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "finance-finance-fpa-analyst",
      "path": "agents/finance-finance-fpa-analyst.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-business-strategist",
      "path": "agents/specialized-business-strategist.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/route_analysis_sop.md"
  ]
}