{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Medical Inventory & Procurement QA",
  "version": "1.0.0",
  "description": "Edge Operations: Purchasing medical supplies, shipping, receiving audits, and ISO compliance sterilization QA.",
  "industry": "medical-practices",
  "tags": [
    "healthcare",
    "inventory",
    "shipping",
    "iso9000",
    "procurement"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-healthcare-marketing-compliance",
      "path": "agents/specialized-healthcare-marketing-compliance.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/inventory_sop.md"
  ]
}