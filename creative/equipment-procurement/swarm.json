{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Studio Equipment Purchasing & Asset Inventory",
  "version": "1.0.0",
  "description": "Edge Operations: Camera/lens procurement, studio shipping logs, asset receiving, and hardware QA.",
  "industry": "media-creative",
  "tags": [
    "creative",
    "procurement",
    "inventory",
    "hardware-qa",
    "cameras"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "paid-media-paid-media-creative-strategist",
      "path": "agents/paid-media-paid-media-creative-strategist.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "project-management-project-management-studio-producer",
      "path": "agents/project-management-project-management-studio-producer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "paid-media-paid-media-auditor",
      "path": "agents/paid-media-paid-media-auditor.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/optics_receiving_sop.md"
  ]
}