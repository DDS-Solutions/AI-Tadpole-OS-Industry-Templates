{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Soil Science & Agronomy Database Indexer",
  "version": "1.0.0",
  "description": "Knowledge Work: Soil telemetry data parsing, crop yields indexing, and agricultural research synthesis.",
  "industry": "agriculture-agtech",
  "tags": [
    "agriculture",
    "soil",
    "agronomy",
    "telemetry",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "design-design-ux-researcher",
      "path": "agents/design-design-ux-researcher.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "engineering-engineering-database-optimizer",
      "path": "agents/engineering-engineering-database-optimizer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "finance-finance-investment-researcher",
      "path": "agents/finance-finance-investment-researcher.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/soil_telemetry_sop.md"
  ]
}