{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Legal Vendor Procurement & QA",
  "version": "1.0.0",
  "description": "Edge Operations: Purchasing audits, contract lifecycle QA, and vendor compliance assessment.",
  "industry": "legal-services",
  "tags": [
    "law",
    "purchasing",
    "qa",
    "vendor-compliance"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-legal-document-review",
      "path": "agents/specialized-legal-document-review.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-recruitment-specialist",
      "path": "agents/specialized-recruitment-specialist.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/procurement_sop.md"
  ]
}