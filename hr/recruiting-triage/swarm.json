{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Recruiting Triage Swarm",
  "version": "1.0.0",
  "author": "HR Systems Group",
  "description": "Designed for parsing candidate resumes, screening against role criteria, and coordinating onboarding files.",
  "industry": "Human Resources",
  "tags": [
    "hr",
    "recruiting",
    "onboarding"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.4
  },
  "roster": [
    {
      "id": "academic-academic-geographer",
      "path": "agents/academic-academic-geographer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-hr-onboarding",
      "path": "agents/specialized-hr-onboarding.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "academic-academic-psychologist",
      "path": "agents/academic-academic-psychologist.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}