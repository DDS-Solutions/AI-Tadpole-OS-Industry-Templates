    {
      "id": "agency_qa_specialist",
      "path": "agents/agency_qa_specialist.json",
      "supervisor": null,
      "priority": "critical"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/recruiting_audit_sop.md"
