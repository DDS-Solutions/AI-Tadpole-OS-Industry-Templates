{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Clinical Trial Management Swarm",
  "version": "1.0.0",
  "author": "PharmaFlow Research",
  "description": "Designed for clinical trial protocol mapping, candidate documentation analysis, and automated adverse event tracking.",
  "industry": "Pharmaceuticals",
  "tags": [
    "pharma",
    "clinical",
    "trials",
    "compliance"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.1
  },
  "roster": [
    {
      "id": "specialized-data-privacy-officer",
      "path": "agents/specialized-data-privacy-officer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-healthcare-marketing-compliance",
      "path": "agents/specialized-healthcare-marketing-compliance.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-hr-onboarding",
      "path": "agents/specialized-hr-onboarding.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}