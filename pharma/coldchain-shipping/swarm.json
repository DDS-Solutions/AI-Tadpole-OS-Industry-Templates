{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Cold-Chain Shipping Receiving & GMP QA",
  "version": "1.0.0",
  "description": "Edge Operations: Thermally managed shipping, clinical stock receiving, and GMP quality inspections.",
  "industry": "pharmaceuticals",
  "tags": [
    "pharma",
    "coldchain",
    "shipping",
    "receiving",
    "gmp",
    "qa"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-supply-chain-strategist",
      "path": "agents/specialized-supply-chain-strategist.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "academic-academic-psychologist",
      "path": "agents/academic-academic-psychologist.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/coldchain_receiving_sop.md"
  ]
}