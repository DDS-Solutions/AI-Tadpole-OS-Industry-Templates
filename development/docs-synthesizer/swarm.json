{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Tech Spec & API Documentation Indexer",
  "version": "1.0.0",
  "description": "Knowledge Work: Parsing codebase schemas, indexing API documentation, and tech spec synthesis.",
  "industry": "software-development",
  "tags": [
    "development",
    "api",
    "documentation",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "engineering-engineering-backend-architect",
      "path": "agents/engineering-engineering-backend-architect.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "engineering-engineering-technical-writer",
      "path": "agents/engineering-engineering-technical-writer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "engineering-engineering-wechat-mini-program-developer",
      "path": "agents/engineering-engineering-wechat-mini-program-developer.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/docs_sop.md"
  ]
}