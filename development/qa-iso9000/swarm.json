{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Release Quality Assurance & ISO 9000",
  "version": "1.0.0",
  "description": "Edge Operations: Software release QA, test compliance auditing, security asset shipping, and patch management.",
  "industry": "software-development",
  "tags": [
    "development",
    "qa",
    "iso9000",
    "release-management",
    "security"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "project-management-project-management-jira-workflow-steward",
      "path": "agents/project-management-project-management-jira-workflow-steward.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "marketing-marketing-cross-border-ecommerce",
      "path": "agents/marketing-marketing-cross-border-ecommerce.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/release_sop.md"
  ]
}