{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "CAD Design Specification Auditor",
  "version": "1.0.0",
  "description": "Knowledge Work: Reviewing product designs, indexing mechanical blueprints, and material compliance audits.",
  "industry": "manufacturing",
  "tags": [
    "manufacturing",
    "cad",
    "specifications",
    "synthesis"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "security-security-architect",
      "path": "agents/security-security-architect.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "testing-testing-accessibility-auditor",
      "path": "agents/testing-testing-accessibility-auditor.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/design_sop.md"
  ]
}