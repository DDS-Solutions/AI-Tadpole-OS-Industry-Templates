{
  "mcpServers": {
    "material-tracking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgresql",
        "postgresql://localhost:5432/inventory_db"
      ]
    },
    "shop-floor-iot": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-mqtt-bridge"
      ],
      "env": {
        "BROKER_URL": "mqtt://localhost:1883"
      }
    }
  }
}