{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Factory Floor ISO 9000 QA & Inventory",
  "version": "1.0.0",
  "description": "Edge Operations: Materials receiving, shipping finished goods, parts inventory audits, and ISO 9000 quality checks.",
  "industry": "manufacturing",
  "tags": [
    "manufacturing",
    "iso9000",
    "qa",
    "inventory",
    "shipping"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-specialized-model-qa",
      "path": "agents/specialized-specialized-model-qa.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/floor_qa_sop.md"
  ]
}