# Tadpole OS Template Store .gitignore
# ------------------------------------

# Operating System Files
.DS_Store
Thumbs.db
*.swp
*~

# Editor / IDE Files
.vscode/
.idea/
*.suo
*.sln
*.code-workspace

# Node / JS / TS (If any testing scripts are added later)
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Python (If any Python-based MCPs or skills are included)
__pycache__/
*.py[cod]
*$py.class
venv/
.env

# Tadpole OS Specific 🚨 Security 🚨
# NEVER commit the actual database if a user accidentally drags it in
*.db
*.sqlite
*.sqlite3-journal
tadpole.db

# NEVER commit actual environment variables or secrets
.env*
!.env.example
secrets.json
api_keys.json

# Ignore any temporary runtime folders users might drag in
tmp/
logs/
.bunker_cache/
