{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "EdTech Curriculum & Course Indexer",
  "version": "1.0.0",
  "description": "Knowledge Work: Educational standards mapping, syllabus content synthesis, and training guideline indexing.",
  "industry": "edtech-training",
  "tags": [
    "education",
    "curriculum",
    "syllabus",
    "indexing"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "specialized-corporate-training-designer",
      "path": "agents/specialized-corporate-training-designer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "support-support-legal-compliance-checker",
      "path": "agents/support-support-legal-compliance-checker.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "design-design-visual-storyteller",
      "path": "agents/design-design-visual-storyteller.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/curriculum_sop.md"
  ]
}