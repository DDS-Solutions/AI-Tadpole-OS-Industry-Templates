{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "School Supplies Purchasing & Textbook Inventory",
  "version": "1.0.0",
  "description": "Edge Operations: Textbook procurement, classroom supplies shipping, receiving audits, and inventory QA.",
  "industry": "education",
  "tags": [
    "education",
    "procurement",
    "inventory",
    "textbooks",
    "supplies"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-specialized-model-qa",
      "path": "agents/specialized-specialized-model-qa.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "engineering-engineering-devops-automator",
      "path": "agents/engineering-engineering-devops-automator.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/supplies_receiving_sop.md"
  ]
}