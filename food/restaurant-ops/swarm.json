{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Restaurant Operations Swarm",
  "version": "1.0.0",
  "author": "FoodService Labs",
  "description": "An optimized swarm for managing kitchen inventory, menu performance, and automated supplier ordering.",
  "industry": "Food & Beverage",
  "tags": [
    "food",
    "restaurant",
    "inventory",
    "ordering"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.3
  },
  "roster": [
    {
      "id": "project-management-project-management-jira-workflow-steward",
      "path": "agents/project-management-project-management-jira-workflow-steward.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-chief-financial-officer",
      "path": "agents/specialized-chief-financial-officer.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-operations-manager",
      "path": "agents/specialized-operations-manager.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}