{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Recipe & Safety Compliance Auditor",
  "version": "1.0.0",
  "description": "Knowledge Work: Analyzing recipe regulations, health guidelines indexing, and labeling audit reporting.",
  "industry": "food-beverage",
  "tags": [
    "food",
    "compliance",
    "safety",
    "recipe-standards"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "specialized-healthcare-marketing-compliance",
      "path": "agents/specialized-healthcare-marketing-compliance.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "support-support-legal-compliance-checker",
      "path": "agents/support-support-legal-compliance-checker.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "finance-finance-bookkeeper-controller",
      "path": "agents/finance-finance-bookkeeper-controller.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/label_sop.md"
  ]
}