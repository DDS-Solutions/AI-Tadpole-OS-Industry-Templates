{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Kitchen Inventory Receiving & Supplier QA",
  "version": "1.0.0",
  "description": "Edge Operations: Purchasing ingredients, temperature shipping checks, receiving logs, and supplier quality audits.",
  "industry": "food-beverage",
  "tags": [
    "food",
    "inventory",
    "shipping",
    "supplier-qa",
    "receiving"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-specialized-model-qa",
      "path": "agents/specialized-specialized-model-qa.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-supply-chain-strategist",
      "path": "agents/specialized-supply-chain-strategist.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/receiving_sop.md"
  ]
}