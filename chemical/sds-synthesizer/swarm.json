{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Safety Data Sheet (SDS) Policy Indexer",
  "version": "1.0.0",
  "description": "Knowledge Work: SDS sheet parsing, OSHA hazard mapping, and health regulations synthesis.",
  "industry": "chemical-sector",
  "tags": [
    "chemical",
    "sds",
    "osha",
    "compliance",
    "safety"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "specialized-data-privacy-officer",
      "path": "agents/specialized-data-privacy-officer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "specialized-healthcare-marketing-compliance",
      "path": "agents/specialized-healthcare-marketing-compliance.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "support-support-legal-compliance-checker",
      "path": "agents/support-support-legal-compliance-checker.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/sds_sop.md"
  ]
}