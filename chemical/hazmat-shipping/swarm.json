{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Hazmat Shipping, Receiving & ISO QA",
  "version": "1.0.0",
  "description": "Edge Operations: Hazmat container shipping, receiving checks, containment inventory, and ISO 9000 compliance audits.",
  "industry": "chemical-sector",
  "tags": [
    "chemical",
    "hazmat",
    "shipping",
    "receiving",
    "iso9000",
    "inventory"
  ],
  "defaults": {
    "model": "gemini-pro-latest",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "finance-finance-bookkeeper-controller",
      "path": "agents/finance-finance-bookkeeper-controller.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": [
    "workflows/hazmat_receiving_sop.md"
  ]
}