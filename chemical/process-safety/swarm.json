{
  "$schema": "https://tadpoleos.dev/schemas/swarm-v1.json",
  "name": "Chemical Safety Swarm",
  "version": "1.0.0",
  "author": "ChemiSafe Compliance",
  "description": "Designed for chemical inventory management, SDS compliance auditing, and safety checklist validation.",
  "industry": "Chemical Sector",
  "tags": [
    "chemical",
    "safety",
    "compliance",
    "auditing"
  ],
  "defaults": {
    "model": "gemini-1.5-flash",
    "temperature": 0.2
  },
  "roster": [
    {
      "id": "gis-gis-qa-engineer",
      "path": "agents/gis-gis-qa-engineer.json",
      "supervisor": null,
      "priority": "critical"
    },
    {
      "id": "security-security-compliance-auditor",
      "path": "agents/security-security-compliance-auditor.json",
      "supervisor": null,
      "priority": "normal"
    },
    {
      "id": "specialized-data-privacy-officer",
      "path": "agents/specialized-data-privacy-officer.json",
      "supervisor": null,
      "priority": "normal"
    }
  ],
  "required_mcps": "mcps.json",
  "global_workflows": []
}